@model List<HappyHearts_Draft.Models.ViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">

    <h1 class="display-5 fw-bold mb-4">
        <i class="fa-solid fa-cart-shopping"></i>
        Shopping Cart
    </h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center p-5">

            <h3>Your cart is currently empty.</h3>

            <p class="mb-4">
                Browse our products and add something for your pets.
            </p>

            <a asp-controller="Shop"
               asp-action="Index"
               class="btn btn-primary btn-lg">

                Continue Shopping

            </a>

        </div>
    }
    else
    {
        decimal total = 0;

        @foreach (var item in Model)
        {
            total += item.Total;

            <div class="card shadow-sm mb-4 border-0 rounded-4">

                <div class="card-body">

                    <div class="row align-items-center">

                        <!-- Image -->

                        <div class="col-md-2 text-center">

                            <img src="~/images/@item.ImageUrl"
                                 class="img-fluid rounded"
                                 style="max-height:120px;"
                                 alt="@item.Name" />

                        </div>

                        <!-- Product -->

                        <div class="col-md-4">

                            <h4 class="fw-bold">
                                @item.Name
                            </h4>

                            <p class="text-muted">
                                Price:
                                <strong>
                                    R @item.Price.ToString("N2")
                                </strong>
                            </p>

                        </div>

                        <!-- Quantity -->

                        <div class="col-md-3 text-center">

                            <form asp-controller="Cart"
                                  asp-action="UpdateQuantity"
                                  method="post">

                                <input type="hidden"
                                       name="cartDetailId"
                                       value="@item.CartDetailId" />

                                <div class="input-group justify-content-center">

                                    <button type="button"
                                            class="btn btn-outline-secondary qty-minus">

                                        -

                                    </button>

                                    <input class="form-control text-center qty-input"
                                           style="max-width:70px;"
                                           type="number"
                                           min="1"
                                           name="quantity"
                                           value="@item.Quantity"
                                           data-price="@item.Price"
                                           data-id="@item.CartDetailId" />

                                    <button type="button"
                                            class="btn btn-outline-secondary qty-plus">

                                        +

                                    </button>

                                </div>

                                

                            </form>

                        </div>

                        <!-- Subtotal -->

                        <div class="col-md-2 text-center">

                            <h5 class="item-total">

                                R @item.Total.ToString("N2")

                            </h5>

                        </div>

                        <!-- Remove -->

                        <div class="col-md-1 text-center">

                            <form asp-controller="Cart"
                                  asp-action="RemoveItem"
                                  method="post">

                                <input type="hidden"
                                       name="cartDetailId"
                                       value="@item.CartDetailId" />

                                <button class="btn btn-danger">

                                    <i class="fa-solid fa-trash"></i>

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        }

        <div class="card shadow border-0 rounded-4">

            <div class="card-body">

                <div class="row">

                    <div class="col-md-8">

                        <h3>Total</h3>

                    </div>

                    <div class="col-md-4 text-end">

                        <h2 class="text-success" id="cartTotal">

                            R @total.ToString("N2")

                        </h2>

                    </div>

                </div>

                <div class="d-grid mt-4">

                    <a asp-controller="Checkout"
                       asp-action="Index"
                       class="btn btn-success btn-lg">

                        Proceed To Checkout

                    </a>

                </div>

            </div>

        </div>
    }

</div>

@section Scripts
{
    <script>

        function recalculateCart()
        {
            let grandTotal = 0;

            document.querySelectorAll(".qty-input").forEach(function(input){

                const price = parseFloat(input.dataset.price);

                const quantity = parseInt(input.value);

                const subtotal = price * quantity;

                input.closest(".row")
                     .querySelector(".item-total")
                     .innerText = "R " + subtotal.toFixed(2);

                grandTotal += subtotal;

            });

            document.getElementById("cartTotal").innerText =
                "R " + grandTotal.toFixed(2);
        }

        document.querySelectorAll(".qty-plus").forEach(function(button){

            button.addEventListener("click", function(){

                const input = this.parentElement.querySelector(".qty-input");

                input.value = parseInt(input.value) + 1;

                recalculateCart();

            });

        });

        document.querySelectorAll(".qty-minus").forEach(function(button){

            button.addEventListener("click", function(){

                const input = this.parentElement.querySelector(".qty-input");

                if(parseInt(input.value) > 1)
                {
                    input.value = parseInt(input.value) - 1;

                    recalculateCart();
                }

            });

        });

        document.querySelectorAll(".qty-input").forEach(function(input){

            input.addEventListener("input", function(){

                if(this.value < 1)
                    this.value = 1;

                recalculateCart();

            });

        });

    </script>
}