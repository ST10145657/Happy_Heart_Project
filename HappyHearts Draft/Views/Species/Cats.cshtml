<div class="cat-page">

    <div class="cat-hero d-flex align-items-center justify-content-center text-center">

        <div class="hero-content">

            <h1 class="display-3 fw-bold text-white">
                Cat Species
            </h1>

            <p class="lead text-white">
                Discover beautiful cats looking for loving homes and learn more about each breed.
            </p>

        </div>

    </div>

    <!-- Search -->
    <div class="row justify-content-center mb-5">

        <div class="col-md-6">

            <input type="text"
                   id="CatsSearch"
                   class="form-control form-control-lg"
                   placeholder="🔍 Search types of Cats..." />

        </div>

    </div>
    <div class="row g-4">

        @foreach (var cat in catList)
        {
            <div class="col-lg-4 col-md-6" data-aos="fade-up">

                <div class="card h-100">

                    <img src="~/images/cats/@cat.Image"
                         class="card-img-top"
                         alt="@cat.Name" />

                    <div class="card-body">

                        <h4 class="fw-bold">
                            @cat.Name
                        </h4>

                        <hr />

                        <p><strong> Colour:</strong> @cat.Colour</p>

                        <p><strong> Size:</strong> @cat.Size</p>

                        <p><strong> Lifespan:</strong> @cat.Lifespan</p>

                        <p><strong> Gender:</strong> @cat.Gender</p>

                        <p><strong> Temperament:</strong> @cat.Temperament</p>

                      @*   <p><strong>💰 Price:</strong> @cat.Price</p> *@

                        <button class="btn btn-primary w-100">

                            Adopt

                        </button>

                    </div>

                </div>

            </div>
        }

    </div>
