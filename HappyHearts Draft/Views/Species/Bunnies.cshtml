@{
    ViewData["Title"] = "Bunnies";
}

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="display-4 fw-bold">

            🐰 Bunnies

        </h1>

        <p class="lead text-muted">

            Small companions with huge personalities.

        </p>

    </div>

    <div class="row">

        <div class="col-lg-4 mb-4">

            <div class="card shadow border-0 rounded-4 h-100">

                <img src="~/images/Bunnies/White Bunny.jpg"
                     class="card-img-top"
                     style="height:300px;object-fit:cover;">

                <div class="card-body">

                    <h3 class="fw-bold">

                        Holland Lop

                    </h3>

                    <hr />

                    <p><strong>Gender:</strong> Male / Female</p>

                    <p><strong>Lifespan:</strong> 2–3 Years</p>

                    <p><strong>Adult Size:</strong> 15 cm</p>

                    <p><strong>Temperament:</strong> Friendly</p>

                    <p><strong>Difficulty:</strong> Beginner</p>

                    <h3 class="text-success">

                        R250

                    </h3>

                </div>

                <div class="card-footer bg-white border-0">

                    <form asp-controller="Cart"
                          asp-action="AddPet"
                          method="post">

                        <input type="hidden"
                               name="petId"
                               value="1" />

                        <div class="input-group mb-3">

                            <button class="btn btn-outline-secondary minus-btn"
                                    type="button">

                                -

                            </button>

                            <input class="form-control text-center quantity-input"
                                   name="quantity"
                                   value="1">

                            <button class="btn btn-outline-secondary plus-btn"
                                    type="button">

                                +

                            </button>

                        </div>

                        <button class="btn btn-success w-100">

                            <i class="fa-solid fa-cart-shopping"></i>

                            Add To Cart

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
<script>

    document.querySelectorAll(".plus-btn").forEach(button=>{

    button.addEventListener("click",function(){

    let input=this.parentElement.querySelector(".quantity-input");

    input.value=parseInt(input.value)+1;

    });

    });

    document.querySelectorAll(".minus-btn").forEach(button=>{

    button.addEventListener("click",function(){

    let input=this.parentElement.querySelector(".quantity-input");

    if(parseInt(input.value)>1)

    input.value=parseInt(input.value)-1;

    });

    });

</script>