@model List<HappyHearts_Draft.Models.Pet>

@{
    ViewData["Title"] = "Bunnies";
}

<div class="fish-page">

    <div class="fish-hero d-flex align-items-center justify-content-center text-center">

        <div class="hero-content">

            <h1 class="display-3 fw-bold text-white">
                Bunnies
            </h1>

            <p class="lead text-white">
                Gentle, playful and full of personality.
            </p>

        </div>

    </div>

    <div class="row justify-content-center mb-5">

        <div class="col-md-6">

            <input type="text"
                   id="BunnySearch"
                   class="form-control form-control-lg"
                   placeholder="🔍 Search Bunnies..." />

        </div>

    </div>

    <div class="row g-4">

        @foreach (var bunny in Model)
        {
            <div class="col-lg-4 col-md-6 pet-card" data-aos="fade-up">

                <div class="card h-100">

                    <img src="~/images/@bunny.ImageUrl"
                         class="card-img-top"
                         alt="@bunny.Name" />

                    <div class="card-body">

                        <h4 class="fw-bold">@bunny.Name</h4>

                        <hr />

                        <p><strong>Breed:</strong> @bunny.Breed</p>

                        <p><strong>Gender:</strong> @bunny.Gender</p>

                        <p><strong>Age:</strong> @bunny.Age Months</p>

                        <p><strong>Colour:</strong> @bunny.Colour</p>

                        <p><strong>Temperament:</strong> @bunny.Temperament</p>

                        <p><strong>Size:</strong> @bunny.Size</p>

                        <p>

                            <strong>Price:</strong>

                            <span class="badge bg-success fs-6">

                                R @bunny.Price.ToString("N2")

                            </span>

                        </p>

                        <form asp-controller="Cart"
                              asp-action="AddPet"
                              method="post">

                            <input type="hidden"
                                   name="petId"
                                   value="@bunny.PetId" />

                            <input type="hidden"
                                   name="quantity"
                                   value="1" />

                            <button class="btn btn-success w-100">

                                <i class="fa-solid fa-cart-shopping"></i>

                                Add To Cart

                            </button>

                        </form>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<script>

    document.getElementById("BunnySearch").addEventListener("keyup", function(){

        let value=this.value.toLowerCase();

        document.querySelectorAll(".pet-card").forEach(card=>{

            card.style.display=
            card.innerText.toLowerCase().includes(value)
            ? ""
            : "none";

        });

    });

</script>