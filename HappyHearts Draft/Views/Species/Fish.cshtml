@model List<HappyHearts_Draft.Models.Pet>

@{
    ViewData["Title"] = "Fish";
}

<div class="fish-page">

<div class="fish-hero d-flex align-items-center justify-content-center text-center">

    <div class="hero-content">

        <h1 class="display-3 fw-bold text-white">
            Fish Species
        </h1>

        <p class="lead text-white">
            Explore freshwater and saltwater fish and learn how to care for them.
        </p>

    </div>

</div>

    <!-- Search -->
    <div class="row justify-content-center mb-5">

        <div class="col-md-6">

            <input type="text"
                   id="FishSearch"
                   class="form-control form-control-lg"
                   placeholder="🔍 Search types of Fish..." />

        </div>

    </div>
    <div class="row g-4">

        @foreach (var fish in Model)
        {
            <div class="col-lg-4 col-md-6 searchable-fish" data-aos="fade-up">

                <div class="card h-100">

                    <img src="~/images/@fish.ImageUrl"
                         class="card-img-top"
                         alt="@fish.Name" />

                    <div class="card-body">

                        <h4 class="fw-bold">
                            @fish.Name
                        </h4>

                        <hr />

                        <p><strong> Type:</strong> @fish.Type</p>

                       

                      

                        <p><strong> Temperature:</strong> @fish.Temperature</p>

                        <p><strong> Lifespan:</strong> @fish.Lifespan</p>

                        <p>
                            <strong> Difficulty:</strong>

                            @if (fish.Difficulty == "Beginner")
                            {
                                <span class="badge bg-success">Beginner</span>
                            }
                            else if (fish.Difficulty == "Intermediate")
                            {
                                <span class="badge bg-warning text-dark">Intermediate</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Advanced</span>
                            }

                        </p>


                            <p>
                                <strong>Price:</strong>
                                <span class="text-success fw-bold">
                                   R @fish.Price.ToString("N2")
                                </span>
                            </p>

                        <form asp-controller="Cart"
                              asp-action="AddPet"
                              method="post">

                            <input type="hidden"
                                   name="petId"
                                   value="@fish.PetId" />

                            <input type="hidden"
                                   name="quantity"
                                   value="1" />

                            <button class="btn btn-success w-100">
                                <i class="fa-solid fa-cart-shopping"></i>
                                Add To Cart
                            </button>

                        </form>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<script>

    document.getElementById("FishSearch").addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        document.querySelectorAll(".searchable-fish").forEach(function (fish) {

            let text = fish.innerText.toLowerCase();

            fish.style.display =
                text.includes(value) ? "" : "none";

        });

    });

</script>
