@model List<HappyHearts_Draft.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }



    <div class="text-center mb-5" data-aos="fade-up">

        <h1 class="display-4 fw-bold">
            Pet Shop
        </h1>

        <p class="lead text-muted">
            Everything your pet needs in one place.
        </p>

    </div>

    <!-- Search -->
    <div class="row justify-content-center mb-5">

        <div class="col-md-7">

            <input class="form-control form-control-lg"
                    type="text"
                    id="ShopSearch"
                    placeholder="🔍 Search products..." />

        </div>

    </div>

    @foreach (var item in Model)
    {
        <div class="product-row mb-4 searchable-product" data-aos="fade-up">

            <div class="row align-items-center">

                <div class="col-lg-3">

                    <img src="@(item.ProductId != null
    ? Url.Content("~/images/shop/" + item.ImageUrl)
    : Url.Content("~/images/" + item.ImageUrl))"
                         class="img-fluid rounded"
                         style="max-height:120px;" />

                </div>

                <div class="col-lg-6">

                    <span class="badge bg-primary mb-2">
                        @item.Category
                    </span>

                    <h3>@item.Name</h3>

                    <p class="text-muted">
                        @item.Description
                    </p>

                </div>



                <div class="col-lg-3 text-center">

                    <h2 class="text-success fw-bold">
                        R @item.Price.ToString("N2")
                    </h2>

                    <form asp-controller="Cart"
                          asp-action="AddProduct"
                          method="post">

                        <input type="hidden"
                               name="productId"
                               value="@item.ProductId" />

                        <!-- Quantity Selector -->
                        <div class="d-flex justify-content-center align-items-center my-3">

                            <button type="button"
                                    class="btn btn-outline-secondary qty-minus">
                                -
                            </button>

                            <input type="number"
                                   name="quantity"
                                   value="1"
                                   min="1"
                                   class="form-control text-center mx-2 qty-input"
                                   style="width:70px;" />

                            <button type="button"
                                    class="btn btn-outline-secondary qty-plus">
                                +
                            </button>

                        </div>


                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.ProductId"
                               class="btn btn-warning w-100 mb-2">
                                <i class="fa fa-pen"></i>
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.ProductId"
                               class="btn btn-danger w-100">
                                <i class="fa fa-trash"></i>
                                Delete
                            </a>
                        }

                        <button type="submit"
                                class="btn btn-success w-100">

                            <i class="fa-solid fa-cart-shopping"></i>

                            Add To Cart

                        </button>

                    </form>

                </div>

            </div>

        </div>
    }

</div>

@section Scripts
{
    <script>

        // Quantity buttons
        document.querySelectorAll(".qty-plus").forEach(button => {

            button.addEventListener("click", function () {

                const input = this.parentElement.querySelector(".qty-input");

                input.value = parseInt(input.value) + 1;

            });

        });

        document.querySelectorAll(".qty-minus").forEach(button => {

            button.addEventListener("click", function () {

                const input = this.parentElement.querySelector(".qty-input");

                let value = parseInt(input.value);

                if (value > 1) {

                    input.value = value - 1;

                }

            });

        });

        // Live Product Search
        document.getElementById("ShopSearch").addEventListener("keyup", function () {

            let value = this.value.toLowerCase();

            document.querySelectorAll(".searchable-product").forEach(function (product) {

                let text = product.innerText.toLowerCase();

                product.style.display =
                    text.includes(value) ? "" : "none";

            });

        });

    </script>
}