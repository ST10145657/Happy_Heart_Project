@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section text-center text-white d-flex align-items-center">

    <div class="container" data-aos="fade-up">

        <h1 class="display-3 fw-bold">
            Welcome to Happy Hearts Pet Store
        </h1>

        <p class="lead mt-3 mb-4">

            Discover healthy pets, premium accessories and everything
            your furry (or finned) friend needs.

        </p>

        <a asp-controller="Shop"
           asp-action="Index"
           class="btn btn-primary btn-lg rounded-pill px-5 me-3">

            Shop Now

        </a>

        <a asp-controller="Species"
           asp-action="Index"
           class="btn btn-outline-light btn-lg rounded-pill px-5">

            Browse Pets

        </a>

    </div>

</section>


<!-- Featured Pets -->

<section class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            Featured Pets

        </h2>

        <p class="text-muted">

            Meet some of our favourite companions.

        </p>

    </div>

    <div class="row g-4">

        <!-- Fish -->

        <div class="col-lg-4">

            <div class="card shadow h-100 border-0">

                <img src="~/images/Fish/Ballon Mollies.jpg"
                     class="card-img-top featured-image">

                <div class="card-body text-center">

                    <span class="badge bg-success mb-3">
                        R60
                    </span>

                    <h4>Goldfish</h4>

                    <p class="text-muted">

                        Beginner friendly freshwater fish perfect
                        for any aquarium.

                    </p>

                    <a asp-controller="Species"
                       asp-action="Fish"
                       class="btn btn-primary">

                        View Fish

                    </a>

                </div>

            </div>

        </div>


        <!-- Hamster -->

        <div class="col-lg-4">

            <div class="card shadow h-100 border-0">

                <img src="~/images/hamster/Hamster 2.jpg"
                     class="card-img-top featured-image">

                <div class="card-body text-center">

                    <span class="badge bg-success mb-3">
                        R250
                    </span>

                    <h4>Syrian Hamster</h4>

                    <p class="text-muted">

                        Friendly, playful and perfect for first-time
                        pet owners.

                    </p>

                    <a asp-controller="Species"
                       asp-action="Hamsters"
                       class="btn btn-primary">

                        View Hamsters

                    </a>

                </div>

            </div>

        </div>


        <!-- Bunny -->

        <div class="col-lg-4">

            <div class="card shadow h-100 border-0">

                <img src="~/images/Bunnies/Brown Bunny.jpg"
                     class="card-img-top featured-image">

                <div class="card-body text-center">

                    <span class="badge bg-success mb-3">
                        R550
                    </span>

                    <h4>Holland Lop</h4>

                    <p class="text-muted">

                        Gentle indoor bunny with adorable floppy ears.

                    </p>

                    <a asp-controller="Species"
                       asp-action="Bunnies"
                       class="btn btn-primary">

                        View Bunnies

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>



<!-- Featured Accessories -->

<section class="bg-light py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">

                Featured Accessories

            </h2>

            <p class="text-muted">

                Everything your pet needs.

            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card shadow-sm text-center">

                    <img src="~/images/shop/net.jpeg"
                         class="card-img-top featured-image">

                    <div class="card-body">

                        <h5>Small Fish Net</h5>

                        <h4 class="text-success">
                            R40
                        </h4>

                        <a asp-controller="Shop"
                           asp-action="Index"
                           class="btn btn-success">

                            Shop Now

                        </a>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow-sm text-center">

                    <img src="~/images/shop/stones.jpeg"
                         class="card-img-top featured-image">

                    <div class="card-body">

                        <h5>Aquarium Stones</h5>

                        <h4 class="text-success">
                            R40
                        </h4>

                        <a asp-controller="Shop"
                           asp-action="Index"
                           class="btn btn-success">

                            Shop Now

                        </a>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow-sm text-center">

                    <img src="~/images/shop/pump102.jpeg"
                         class="card-img-top featured-image">

                    <div class="card-body">

                        <h5>Fish Pump</h5>

                        <h4 class="text-success">
                            R250
                        </h4>

                        <a asp-controller="Shop"
                           asp-action="Index"
                           class="btn btn-success">

                            Shop Now

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>



<!-- Why Choose Us -->

<section class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            Why Shop With Happy Hearts?

        </h2>

    </div>

    <div class="row text-center">

        <div class="col-md-3">

            <i class="fa-solid fa-fish fa-3x text-primary mb-3"></i>

            <h5>Healthy Pets</h5>

            <p>We care for every pet before they find a new home.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-box-open fa-3x text-primary mb-3"></i>

            <h5>Quality Products</h5>

            <p>Only trusted products for your pets.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-heart fa-3x text-primary mb-3"></i>

            <h5>Friendly Service</h5>

            <p>Helping you choose the perfect companion.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-truck fa-3x text-primary mb-3"></i>

            <h5>Growing Every Day</h5>

            <p>New pets and products arriving regularly.</p>

        </div>

    </div>

</section>