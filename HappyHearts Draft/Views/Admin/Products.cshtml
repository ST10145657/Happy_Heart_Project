@model List<HappyHearts_Draft.Models.Product>

@{
    ViewData["Title"] = "Manage Products";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold">
                Product Management
            </h1>

            <p class="text-muted">
                Add, edit and remove products from Happy Hearts.
            </p>

        </div>

        <a asp-action="AddProduct"
           class="btn btn-success">

            <i class="fa-solid fa-plus"></i>

            Add Product

        </a>

    </div>

    <table class="table table-hover align-middle">

        <thead class="table-dark">

            <tr>

                <th>Image</th>

                <th>Name</th>

                <th>Category</th>

                <th>Price</th>

                <th>Stock</th>

                <th class="text-center">
                    Actions
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td width="90">

                        <img src="~/images/shop/@item.ImageUrl"
                             width="70"
                             class="rounded shadow" />

                    </td>

                    <td>

                        <strong>@item.Name</strong>

                    </td>

                    <td>

                        @item.Category

                    </td>

                    <td>

                        R @item.Price.ToString("N2")

                    </td>

                    <td>

                        @item.Stock

                    </td>

                    <td class="text-center">

                        <a asp-action="EditProduct"
                           asp-route-id="@item.ProductId"
                           class="btn btn-warning btn-sm">

                            <i class="fa-solid fa-pen"></i>

                        </a>

                        <a asp-action="DeleteProduct"
                           asp-route-id="@item.ProductId"
                           class="btn btn-danger btn-sm">

                            <i class="fa-solid fa-trash"></i>

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
